# WebControl4 Configuration
# Copy this file to .env and edit as needed.
# All values are optional — defaults match the original plain-HTTP behavior.

# --- Server port ---
PORT=3000

# --- HTTPS ---
HTTPS_ENABLED=false
HTTPS_PORT=3443
# Paths to PEM-encoded certificate and key (optional).
# If HTTPS_ENABLED=true and these are omitted, a self-signed cert is auto-generated.
TLS_CERT_FILE=
TLS_KEY_FILE=
# Redirect HTTP -> HTTPS when HTTPS is enabled (default true)
HTTP_REDIRECT=true

# --- Google OAuth ---
# Set these to require Google sign-in for the web app and MCP clients.
# Register at https://console.cloud.google.com/apis/credentials
# Add redirect URIs: http://localhost:3000/auth/google/callback
#                     http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of allowed email addresses (empty = allow all Google accounts)
ALLOWED_EMAILS=

# --- MCP Server ---
MCP_HTTP_PORT=3001
MCP_CONTROLLER_IP=mock
# MCP_DIRECTOR_TOKEN=
