# WebControl4 Configuration
# Copy this file to .env and edit as needed.
# All values are optional — defaults use port 3443.

# --- Server port ---
# Only used when HTTPS_ENABLED=false.
PORT=3443

# --- HTTPS ---
HTTPS_ENABLED=false
HTTPS_PORT=3443
# Paths to PEM-encoded certificate and key (optional).
# If HTTPS_ENABLED=true and these are omitted, a self-signed cert is auto-generated.
TLS_CERT_FILE=
TLS_KEY_FILE=

# --- Public HTTPS via DuckDNS + Let's Encrypt (optional) ---
# PUBLIC_HOSTNAME should be the externally trusted name clients will use.
# For DuckDNS, PUBLIC_HOSTNAME is typically "<subdomain>.duckdns.org" and
# DUCKDNS_DOMAIN is just the "<subdomain>" part.
PUBLIC_HOSTNAME=
DUCKDNS_DOMAIN=
DUCKDNS_TOKEN=
ACME_EMAIL=
ACME_ACCOUNT_KEY_FILE=data/acme/account.key.pem
ACME_DNS_DELAY_MS=45000

# --- Google OAuth ---
# Set these to require Google sign-in for the web app and MCP clients.
# Register at https://console.cloud.google.com/apis/credentials
# Add redirect URIs: https://localhost:3443/auth/google/callback
#                     http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of allowed email addresses (empty = allow all Google accounts)
ALLOWED_EMAILS=

# --- Control4 API ---
# Application key for Control4 cloud authentication (optional override)
# C4_APPLICATION_KEY=

# --- Pushover Notifications ---
# Get your user key from pushover.net and create an app at pushover.net/apps/build
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
PUSHOVER_DEVICE=                # optional — blank sends to all devices
PUSHOVER_ENABLED=true           # kill switch

# --- Ring Integration ---
# Refresh token for Ring cloud API (optional — can also authenticate via web UI)
# Get a token by running: npx -p ring-client-api ring-auth-cli
RING_REFRESH_TOKEN=

# --- MCP Server ---
MCP_HTTP_PORT=3001
MCP_CONTROLLER_IP=mock
# MCP_DIRECTOR_TOKEN=
